# Copy this file to `.env` and fill it in, then run `docker compose up -d`.

# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token. Create an application + bot at
# https://discord.com/developers/applications and paste its token here.
DISCORD_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────

# The Spotify Connect device name the bot advertises. Defaults to "Spoticord".
# DEVICE_NAME=Spoticord

# Directory where the reusable Spotify credentials are cached. Defaults to /data
# (mounted as a Docker volume by docker-compose so the login survives restarts).
# CACHE_DIR=/data

# ── Optional: /play and /queue (Spotify search) ──────────────────────────────
#
# These commands use Spotify's public Web API, which needs your own (free)
# Spotify app — librespot's built-in token is rejected for it. To enable them:
#   1. Create an app at https://developer.spotify.com/dashboard
#   2. In the app settings, add this exact Redirect URI:
#        http://127.0.0.1:8898/callback
#   3. Paste the app's Client ID and Client Secret below.
#   4. Restart the bot once and approve the SECOND authorization URL it prints
#      (you must be able to reach 127.0.0.1:8898 from your browser).
# Leave these unset to disable /play and /queue.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
#
# Override only if you registered a different Redirect URI (must match exactly).
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8898/callback

# Only used by debug builds: the guild (server) ID to register slash commands in.
# Leave unset for the release image (commands register globally).
# GUILD_ID=
