# Copy this file to `.env` and fill in the values, then run `docker compose up -d`.

# ── Required ──────────────────────────────────────────────────────────────────

# Discord bot token. Create an application + bot at
# https://discord.com/developers/applications and paste its token here.
DISCORD_TOKEN=

# Spotify application credentials, from https://developer.spotify.com/dashboard
# Used to refresh access tokens.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Base URL of a spoticord-link frontend instance, used so users can link their
# Spotify account to the bot. You must host this yourself — see
# https://github.com/SpoticordMusic/spoticord-link
# Account linking (the /link command) will NOT work without it.
LINK_URL=

# ── Provided by docker-compose (change only if you use external services) ─────

# PostgreSQL connection string. Points at the bundled `postgres` service.
# The bot runs its own migrations on startup, so an empty database is fine.
DATABASE_URL=postgres://spoticord:spoticord@postgres:5432/spoticord

# Redis connection URL. Required because the default build enables the `stats`
# feature. Points at the bundled `redis` service.
KV_URL=redis://redis:6379

# ── Optional ──────────────────────────────────────────────────────────────────

# Only used by debug builds: the guild (server) ID to register slash commands in.
# Leave unset for the release image (commands register globally).
# GUILD_ID=
